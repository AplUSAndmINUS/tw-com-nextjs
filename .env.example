# =============================================================================
# TW.com Next.js — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values you need.
# NEVER commit .env.local or any file containing real secrets.

# =============================================================================
# ENVIRONMENT (build-time — baked into the static export)
# =============================================================================
# Sets the deployment environment.  Accepted values: dev | test | prod
# DEV and TEST environments display a token gate before showing the site.
# PROD is publicly accessible with no token required.
#
# This value is set automatically in the GitHub Actions workflows
# (see .github/workflows/).  You only need to set it locally when testing
# the token gate UI for DEV and TEST environments.
#
NEXT_PUBLIC_ENVIRONMENT=dev

# =============================================================================
# ACCESS TOKEN (runtime — Azure Function server-side only)
# =============================================================================
# These variables are consumed by the /api/auth/validate-token Azure Function
# and must be set as Application Settings in Azure Static Web Apps.
# They are NEVER exposed to the browser.
#
# ACCESS_TOKEN  — The secret token users must enter to access DEV/TEST sites.
# ENVIRONMENT   — The runtime environment label (dev | test | prod).
#                 Used by the Azure Function to decide whether a token check
#                 is required.  Should match NEXT_PUBLIC_ENVIRONMENT.
#
# ACCESS_TOKEN=your-secure-token-here
# ENVIRONMENT=dev

# =============================================================================
# CONTACT FORM (runtime — Azure Function server-side only)
# =============================================================================
# SMTP2GO_API_KEY=your-smtp2go-api-key
# CONTACT_FROM_EMAIL=noreply@terencewaters.com
# CONTACT_TO_EMAIL=hello@terencewaters.com

# =============================================================================
# RECAPTCHA (spam protection)
# =============================================================================
# Google reCAPTCHA v3 keys for contact form spam protection
# Get keys from: https://www.google.com/recaptcha/admin
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key-here
# RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key-here

# =============================================================================
# YOUTUBE API
# =============================================================================
# YOUTUBE_API_KEY=your-youtube-api-key