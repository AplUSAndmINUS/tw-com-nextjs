# =============================================================================
# TW.com Next.js — Environment Variables (Frontend Only)
# =============================================================================
# Copy this file to .env.local and fill in the values you need.
# NEVER commit .env.local or any file containing real secrets.
#
# This file is for FRONTEND / BUILD-TIME variables only.
# For Azure Functions server-side configuration, see api/local.sample.settings.json

# =============================================================================
# ENVIRONMENT (build-time — baked into the static export)
# =============================================================================
# Sets the deployment environment.  Accepted values: dev | test | prod
# DEV and TEST environments display a token gate before showing the site.
# PROD is publicly accessible with no token required.
#
# This value is set automatically in the GitHub Actions workflows
# (see .github/workflows/).  You only need to set it locally when testing
# the token gate UI for DEV and TEST environments.
#
NEXT_PUBLIC_ENVIRONMENT=dev

# API Configuration (local development)
NEXT_PUBLIC_API_URL=http://localhost:7071

# =============================================================================
# RECAPTCHA (frontend — spam protection)
# =============================================================================
# Google reCAPTCHA v3 site key (public, frontend use)
# Get keys from: https://www.google.com/recaptcha/admin
# The secret key goes in api/local.settings.json (server-side only)
#
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key-here
